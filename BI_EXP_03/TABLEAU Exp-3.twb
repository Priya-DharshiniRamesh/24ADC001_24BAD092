    <worksheet name='Summary Metrics'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='9'>Summary Metrics </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource name='Sample - Superstore' />
          </datasources>
          <datasource-dependencies datasource='Sample - Superstore'>
            <column caption='Sales_Capped' datatype='real' name='[Calculation_1930767701426177]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Sales]&gt;5000 THEN 5000&#13;&#10;ELSE[Sales]&#13;&#10;END' />
            </column>
            <column caption='Sales Nulls' datatype='integer' name='[Calculation_1952483427221505]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IIF(ISNULL([Sales]), 1, 0))' />
            </column>
            <column caption='Region Nulls' datatype='integer' name='[Calculation_1952483427389442]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IIF(ISNULL([Region]), 1, 0))' />
            </column>
            <column caption='Profit Nulls' datatype='integer' name='[Calculation_1952483427782659]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IIF(ISNULL([Profit]), 1, 0))' />
            </column>
            <column caption='Outlier Flag' datatype='integer' name='[Calculation_1952483428007940]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IIF([Profit] &lt; -2000 OR [Profit] &gt; 5000, 1, 0)' />
            </column>
            <column caption='Outliers Count' datatype='integer' name='[Calculation_1952483428380677]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1952483428007940])' />
            </column>
            <column caption='Completeness %' datatype='integer' name='[Calculation_1952483430719496]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='100' />
            </column>
            <column caption='Total Records' datatype='integer' name='[Calculation_1952483442069513]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Order ID])' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[Order ID]' role='dimension' type='nominal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column aggregate-role-from='[State/Province]' datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1930767701426177]' derivation='Sum' name='[sum:Calculation_1930767701426177:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483428007940]' derivation='Sum' name='[sum:Calculation_1952483428007940:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483430719496]' derivation='Sum' name='[sum:Calculation_1952483430719496:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483427221505]' derivation='User' name='[usr:Calculation_1952483427221505:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483427389442]' derivation='User' name='[usr:Calculation_1952483427389442:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483427782659]' derivation='User' name='[usr:Calculation_1952483427782659:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483428380677]' derivation='User' name='[usr:Calculation_1952483428380677:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1952483442069513]' derivation='User' name='[usr:Calculation_1952483442069513:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[Sample - Superstore].[:Measure Names]'>
