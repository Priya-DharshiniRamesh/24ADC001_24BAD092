      <aliases enabled='yes' />
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Postal Code_Clean' datatype='real' name='[Calculation_1930767699517440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Sales],0)' />
      </column>
      <column caption='Sales_Capped' datatype='real' name='[Calculation_1930767701426177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Sales]&gt;5000 THEN 5000&#13;&#10;ELSE[Sales]&#13;&#10;END' />
      </column>
      <column caption='Outlier' datatype='string' name='[Calculation_1930767701803010]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF[Sales]&gt;5000 THEN &quot;outlier&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Sales Nulls' datatype='integer' name='[Calculation_1952483427221505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF(ISNULL([Sales]), 1, 0))' />
      </column>
      <column caption='Region Nulls' datatype='integer' name='[Calculation_1952483427389442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF(ISNULL([Region]), 1, 0))' />
      </column>
      <column caption='Profit Nulls' datatype='integer' name='[Calculation_1952483427782659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF(ISNULL([Profit]), 1, 0))' />
      </column>
      <column caption='Outlier Flag' datatype='integer' name='[Calculation_1952483428007940]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Profit] &lt; -2000 OR [Profit] &gt; 5000, 1, 0)' />
      </column>
      <column caption='Outliers Count' datatype='integer' name='[Calculation_1952483428380677]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1952483428007940])' />
      </column>
      <column caption='Completeness %' datatype='integer' name='[Calculation_1952483430719496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100' />
      </column>
      <column caption='Total Records' datatype='integer' name='[Calculation_1952483442069513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Order ID])' />
      </column>
